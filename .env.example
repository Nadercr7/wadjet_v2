# ── Wadjet v3 Beta — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# Lines with empty values are optional in development, REQUIRED in production.

# ── Environment ──────────────────────────────────────────────────────────
# "development" auto-generates secrets and shows /docs. "production" requires all secrets.
ENVIRONMENT=development

# ── Security (REQUIRED in production) ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
CSRF_SECRET=

# How many reverse proxies sit in front of the app (0=direct, 1=Render/nginx)
TRUSTED_PROXY_DEPTH=1

# ── Database ─────────────────────────────────────────────────────────────
# SQLite (default) or PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///data/wadjet.db

# ── AI Services (comma-separated keys for rotation) ─────────────────────
# Gemini (primary AI — chat, translation, TTS)
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Grok / xAI (fallback for chat)
GROK_API_KEYS=
GROK_MODEL=grok-4-latest

# Groq (fallback for chat, TTS, STT)
GROQ_API_KEYS=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Cloudflare Workers AI (image generation)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_VISION_MODEL=@cf/meta/llama-3.2-11b-vision-instruct

# ── ML Model Paths (relative to project root) ───────────────────────────
HIEROGLYPH_DETECTOR_PATH=models/hieroglyph/detector/glyph_detector_uint8.onnx
HIEROGLYPH_CLASSIFIER_PATH=models/hieroglyph/classifier/hieroglyph_classifier.onnx
LABEL_MAPPING_PATH=models/hieroglyph/classifier/label_mapping.json
LANDMARK_MODEL_PATH=models/landmark/landmark_classifier_uint8.onnx
LANDMARK_LABEL_MAPPING_PATH=models/landmark/landmark_label_mapping.json

# ── Embedding / Translation Data ─────────────────────────────────────────
FAISS_INDEX_PATH=data/embeddings/corpus.index
CORPUS_PATH=data/embeddings/corpus_ids.json

# ── Detection Tuning ─────────────────────────────────────────────────────
DETECTION_CONFIDENCE_THRESHOLD=0.15

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
BASE_URL=https://wadjet.onrender.com
