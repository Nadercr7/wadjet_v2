# Environment
ENVIRONMENT=development

# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
CSRF_SECRET=

# Trusted proxy depth (0=direct, 1=one reverse proxy like Render)
TRUSTED_PROXY_DEPTH=1

# Gemini API keys (comma-separated for rotation)
GEMINI_API_KEYS=key1,key2,key3

# Model paths (relative to project root)
HIEROGLYPH_DETECTOR_PATH=models/hieroglyph/detector/glyph_detector_uint8.onnx
HIEROGLYPH_CLASSIFIER_PATH=models/hieroglyph/classifier/hieroglyph_classifier_uint8.onnx
LABEL_MAPPING_PATH=models/hieroglyph/label_mapping.json
FAISS_INDEX_PATH=data/embeddings/corpus.index
CORPUS_PATH=data/embeddings/corpus_ids.json

# Landmark model paths
LANDMARK_MODEL_PATH=models/landmark/landmark_classifier_uint8.onnx
LANDMARK_LABEL_MAPPING_PATH=models/landmark/landmark_label_mapping.json

# Server
HOST=0.0.0.0
PORT=8000
